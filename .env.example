# App
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:3000

# CORS
# Use comma-separated list for multiple origins
CORS_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/roamer_backend?schema=public

# Auth
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=roamer_access_token
JWT_COOKIE_MAX_AGE_MS=604800000

# Email (Resend)
RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM_EMAIL=no-reply@yourdomain.com

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Dev helper
DEV_SKIP_EMAIL_VERIFICATION=false

# Storage mode
# local = save files under backend/public/uploads
# gcp   = upload to Google Cloud Storage bucket
STORAGE_PROVIDER=local

# Google Cloud Storage (required if STORAGE_PROVIDER=gcp)
GCP_PROJECT_ID=replace-with-gcp-project-id
GCP_BUCKET_NAME=replace-with-gcp-bucket-name

# Choose one credentials strategy:
# 1) File path (recommended for local development)
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-service-account.json
# 2) Inline JSON (recommended for cloud deployment)
GOOGLE_APPLICATION_CREDENTIALS_JSON=

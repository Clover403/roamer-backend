# Backend server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Local PostgreSQL (change username/password/database as needed)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/roamer_backend?schema=public"

# Auth
JWT_SECRET="replace-with-strong-random-secret"
JWT_EXPIRES_IN="7d"
JWT_COOKIE_NAME="roamer_access_token"
JWT_COOKIE_MAX_AGE_MS=604800000
